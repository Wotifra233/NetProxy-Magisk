{
  "dns": {
    "servers": [
      {
        "tag": "cloudflare",
        "type": "https",
        "server": "1.1.1.1",
        "detour": "Proxy"
      },
      {
        "tag": "ali",
        "type": "https",
        "server": "223.5.5.5"
      },
      {
        "tag": "remote",
        "type": "fakeip",
        "inet4_range": "198.18.0.0/15",
        "inet6_range": "fc00::/18"
      }
    ],
    "rules": [
      {
        "clash_mode": "Direct",
        "action": "route",
        "server": "ali"
      },
      {
        "clash_mode": "Global",
        "action": "route",
        "server": "remote"
      },
      {
        "rule_set": [
          "direct",
          "alibaba",
          "category-games@cn"
        ],
        "action": "route",
        "server": "ali",
        "clash_mode": "Rule"
      },
      {
        "rule_set": [
          "proxy"
        ],
        "action": "route",
        "server": "remote"
      },
      {
        "type": "logical",
        "mode": "and",
        "rules": [
          {
            "clash_mode": "AllowAds",
            "invert": true
          },
          {
            "rule_set": [
              "block",
              "AWAvenue",
              "category-ads-all"
            ]
          }
        ],
        "action": "reject"
      },
      {
        "rule_set": [
          "cn-domain"
        ],
        "action": "route",
        "server": "ali",
        "clash_mode": "Rule"
      },
      {
        "query_type": [
          "A",
          "AAAA"
        ],
        "action": "route",
        "server": "remote"
      }
    ],
    "strategy": "ipv4_only"
  }
}
