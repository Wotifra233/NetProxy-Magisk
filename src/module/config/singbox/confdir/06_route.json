{
  "route": {
    "default_domain_resolver": "ali",
    "default_http_client": "rule-set-download",
    "rule_set": [
      {
        "tag": "block",
        "type": "local",
        "format": "source",
        "path": "./source/block.json"
      },
      {
        "tag": "direct",
        "type": "local",
        "format": "source",
        "path": "./source/direct.json"
      },
      {
        "tag": "proxy",
        "type": "local",
        "format": "source",
        "path": "./source/proxy.json"
      },
      {
        "tag": "AWAvenue",
        "type": "remote",
        "format": "source",
        "url": "https://raw.githubusercontent.com/TG-Twilight/AWAvenue-Ads-Rule/refs/heads/main/Filters/AWAvenue-Ads-Rule-Singbox.json",
        "update_interval": "24h",
        "path": "./source/AWAvenue.json"
      },
      {
        "tag": "category-ads-all",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/CHIZI-0618/v2ray-rules-dat/release/singbox_rule_set/geosite-category-ads-all.srs",
        "update_interval": "24h",
        "path": "./source/category-ads-all.srs"
      },
      {
        "tag": "alibaba",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-alibaba.srs",
        "update_interval": "24h",
        "path": "./source/alibaba.srs"
      },
      {
        "tag": "category-games@cn",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-category-games@cn.srs",
        "update_interval": "24h",
        "path": "./source/category-games@cn.srs"
      },
      {
        "tag": "cn-domain",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/CHIZI-0618/v2ray-rules-dat/release/singbox_rule_set/geosite-cn.srs",
        "update_interval": "24h",
        "path": "./source/cn.srs"
      },
      {
        "tag": "cn-ip",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/sing/geo/geoip/cn.srs",
        "update_interval": "10d",
        "path": "./source/cn-ip.srs"
      }
    ],
    "rules": [
      {
        "action": "sniff",
        "timeout": "1s"
      },
      {
        "action": "sniff-override-destination"
      },
      {
        "ip_cidr": [
          "198.18.0.0/15",
          "fc00::/18"
        ],
        "action": "route",
        "outbound": "Proxy"
      },
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          {
            "port": 53
          },
          {
            "protocol": "dns"
          }
        ],
        "action": "hijack-dns"
      },
      {
        "clash_mode": "Direct",
        "action": "route",
        "outbound": "direct"
      },
      {
        "rule_set": [
          "direct",
          "alibaba",
          "category-games@cn"
        ],
        "action": "route",
        "outbound": "direct",
        "clash_mode": "Rule"
      },
      {
        "rule_set": [
          "proxy"
        ],
        "action": "route",
        "outbound": "Proxy"
      },
      {
        "type": "logical",
        "mode": "and",
        "rules": [
          {
            "clash_mode": "AllowAds",
            "invert": true
          },
          {
            "rule_set": [
              "block",
              "AWAvenue",
              "category-ads-all"
            ]
          }
        ],
        "action": "reject"
      },
      {
        "rule_set": [
          "cn-domain"
        ],
        "action": "route",
        "outbound": "direct",
        "clash_mode": "Rule"
      },
      {
        "action": "resolve",
        "match_only": true,
        "strategy": "ipv4_only",
        "server": "cloudflare"
      },
      {
        "rule_set": "cn-ip",
        "action": "route",
        "outbound": "direct",
        "clash_mode": "Rule"
      },
      {
        "ip_is_private": true,
        "outbound": "direct"
      }
    ],
    "find_process": true,
    "final": "Proxy"
  }
}
